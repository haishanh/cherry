{
  "name": "cherry",
  "version": "0.0.8",
  "private": true,
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.8.0",
  "license": "UNLICENSED",
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-svelte"
    ]
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "dev": "vite dev",
    "test": "vitest",
    "do": "NODE_OPTIONS='--import tsx' node",
    "build": "vite build",
    "preview": "vite preview",
    "package": "svelte-package",
    "sync": "svelte-kit sync",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "bundle:cli": "esbuild src/cli/index.ts --bundle --minify --platform=node --target=node24 --outfile=cherry --external:@node-rs/argon2 --external:@node-rs/* --external:better-sqlite3",
    "fetch:signal-tokenizer": "node scripts/fetch-signal-tokenizer.mjs",
    "cherry": "tsx src/cli/index.ts",
    "lint": "prettier --check src scripts && eslint --cache src",
    "lint:fix": "eslint --cache --fix src",
    "prettier:fix": "prettier --write src scripts",
    "fix": "pnpm lint:fix && pnpm prettier:fix"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fontsource/inter": "5.2.8",
    "@lucide/svelte": "1.21.0",
    "@sveltejs/adapter-node": "5.5.5",
    "@sveltejs/kit": "2.66.0",
    "@sveltejs/package": "2.5.8",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/debug": "4.1.13",
    "@types/estree": "1.0.9",
    "autoprefixer": "10.5.0",
    "date-fns": "4.4.0",
    "domhandler": "6.0.1",
    "esbuild": "0.28.1",
    "esbuild-register": "3.6.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-svelte": "^3.19.0",
    "file-selector": "2.1.2",
    "globals": "17.6.0",
    "ky": "2.0.2",
    "nanoid": "5.1.14",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "sade": "1.8.1",
    "sass": "1.101.0",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "svelte-file-dropzone": "2.0.9",
    "tiny-invariant": "1.3.3",
    "tsconfig-paths": "4.2.0",
    "tslib": "2.8.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "uint8array-extras": "1.5.0",
    "undici": "8.5.0",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1073.0",
    "@aws-sdk/lib-storage": "3.1073.0",
    "@node-rs/argon2": "2.0.2",
    "better-sqlite3": "12.11.1",
    "csv-stringify": "6.8.0",
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "file-type": "22.0.1",
    "htmlparser2": "12.0.0",
    "tar": "7.5.16",
    "zod": "4.4.3"
  }
}
